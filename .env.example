# LLM API for AI Health Companion
# This app is implemented to work with OpenAI-compatible Chat Completions APIs.
# Create a .env file in the project root if you want AI translations.

# Option A: OpenAI
# VITE_OPENAI_API_KEY=your_key
# VITE_OPENAI_MODEL=gpt-4o-mini

# Option B: OpenAI-compatible endpoint (e.g., local/third-party)
# VITE_LLM_API_URL=https://api.openai.com/v1/chat/completions
# VITE_OPENAI_API_KEY=your_key
# VITE_LLM_MODEL=gpt-4o-mini

# If keys are missing, the app will fall back to the existing rule-based insights.

